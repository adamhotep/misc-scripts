use Getopt::Long qw(:config no_ignore_case bundling);
my %opt = ();
my $o = "";
if (-t 0 and @ARGV == 1 and $ARGV[0] eq "-h") { timecalc_help(); exit 0; }
GetOptions(\%opt, qw/ help version|ver|V|v human|h seconds|s test time|t /);
if ($opt{help}) 	{ timecalc_help();	exit 0; }
if ($opt{version})	{ timecalc_version();	exit 0; }
if ($opt{test}) 	{ timecalc_testsuite();	exit 0; }

if ($opt{human})	{ $o = "human"; }
if ($opt{seconds})	{ $o = "seconds"; }
if ($opt{time}) 	{ $o = "time"; }

$tcPROGRAM = $0 =~ s/.*\///r;
for (@ARGV ? @ARGV : <>) {
  my $time = timecalc($_, $o);
  if (defined $time) { print "$time\n"; }
  else { timecalc_err($_); exit 1; }
}
