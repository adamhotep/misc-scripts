# timecalc_err: string -> VOID
# report that string is bad, suggest help
sub timecalc_err {
  print STDERR "$tcPROGRAM: `@_' is neither a time nor a number of seconds.\n";
  print STDERR timecalc_usage();
  print STDERR "Try `$tcPROGRAM --help' for more information.\n";
}

# There are sooo many ways to represent a number. This gets most (in radix 10).
my $num_re = '(?= \.? [0-9] ) [0-9]* (?: \. [0-9]* )? (?: [Ee] [+-]? [0-9]+ )?';

sub human2time {
  $_ = shift @_;

  # collapse weeks into days
  s@ ( $num_re ) ( \s* ) w (?: ( $num_re ) \s* d )?
   @ ( ($3 // 0) + $1 * 7) . $2 . "d"
   @ex;

  # allow for colon-delimited H:M or H:M:S
  s@ ( [yd] \s* $num_re ) : ( $num_re ) (?: : ( $num_re ) )? \s* $
   @ sprintf("%sh%sm%ss", $1, $2, $3 // 0)
   @ixe;

  @_ = m@
    ^
    \s*+
    (?= \S )
    (?: ( $num_re ) \s* y \s* )?
    (?: ( $num_re ) \s* d \s* )?
    (?: ( $num_re ) \s* h \s* )?
    (?: ( $num_re ) \s* m \s* )?
    (?: ( $num_re ) \s* s \s* )?
    $
  @ix;
  return $_ unless @_;
  $_ = join(":", map { $_ // "0" } @_);
  s/^[0:]+//;	# strip leading zeroed fields
  return $_;
}

sub time2sec {
  my ($time) = @_;
  my $temp = $time;
  $time = 0;
  foreach my $field (1, $min, $hour, $day, $year) {
    $_ = $temp;
    s/.*?([^:]+)$/$1/;
    $temp =~ s/^(.*?):?[^:]+$/$1/;
    if ($_ =~ /./) { $time = $time + ($field * $_); }
  }
  print STDERR "Ignored fields larger than years, $temp\n" if $temp =~ /./;
  return $time;
}

sub sec2time {
  my ($time, $option) = @_;
  my ($years, $days, $hours, $mins, $secs);
  $time -= $year * ($years = int ($time/$year));
  $time -= $day  * ($days  = int ($time/$day));
  $time -= $hour * ($hours = int ($time/$hour));
  $time -= $min  * ($mins  = int ($time/$min));
  my $template = "%d:%d:%02d:%02d:%06.3f";
  if ($option eq "human") { $template = "%dy %dd %dh %dm %.3f"; } # add s later
  $time = sprintf($template, $years, $days, $hours, $mins, $time);
  $time =~ s/^[0:ydhm ]*(.+[:ydhm ].+?)\.?0*$/$1/;  # remove lead & tail zeros
  if ($option eq "human") {
    $time .= "s" if $time =~ /[0-9]$/;
    $time =~ s/(?<![0-9])[0dhms ]+$//;	# remove trailing empty units
  }
  return $time;
}

# timecalc: string|number [time|seconds] -> number|string
# Convert a colon-separated time to its value in seconds or vice-versa, units ok
sub timecalc {
  my $output = "";
  my $time = shift;
  my $option = shift // "";

  # Accept -t/--time and -s/--seconds to force the output
  if ($option eq "human")	{ $output = "time"; }
  elsif ($option eq "time")	{ $output = "time"; }
  elsif ($option eq "seconds")	{ $output = "seconds"; }
  elsif ($option ne "") 	{ die "invalid option $option\n"; }

  # use the first line of input if no data was passed from the command line
  if ($time eq "") { $time = <STDIN>; }

  my $neg = "";

  # negative values are noted, removed, and prepended to end result
  if ($time =~ /^-[0-9]/) { $neg="-"; $time =~ s/^-(.*)$/$1/; }

  # support mixes of named units and colon-delimited predecessors
  $time =~ s/ : ( $num_re \s* s ) /m$1/x;
  $time =~ s/ : ( $num_re \s* m ) /h$1/x;
  $time =~ s/ : ( $num_re \s* h ) /d$1/x;
  $time =~ s/ : ( $num_re \s* d ) /y$1/x;

  # HUMAN -> TIME
  my $orig_time = $time;
  $time = human2time($time);	# direct mapping (not cleaned yet)
  if ($orig_time ne $time and $option ne "") {
    if ($orig_time =~ /[ydhm][0-9]/) { $output ||= "seconds" }
    else { $output ||= "time" }
  }

  # TIME -> SECONDS
  if ($time =~ / ^ $num_re (?: : $num_re )+ $ /x) {
    $time = time2sec($time);
    $time = sec2time($time, $option) if $output =~ /time/;  # --time forced
  }

  # SECONDS -> TIME
  elsif ($time =~ / ^ $num_re $ /x) {
    $time = sec2time($time, $option);
    $time = time2sec($time) if $output =~ /seconds/;  # --seconds forced
  }

  # INVALID INPUT
  else { return undef; }

  return "$neg$time";
}


